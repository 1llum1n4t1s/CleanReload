{
  "manifest_version": 3,
  "name": "Clean Reload",
  "description": "ワンクリックでキャッシュを完全クリアしてページを再読み込みします。",
  "version": "1.0.2",
  "action": {
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    },
    "default_title": "Clean Reload"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "browsingData"
  ]
}
